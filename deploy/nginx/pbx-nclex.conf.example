# Host nginx reverse proxy for PBX NCLEX.
# Install this on the host, for example:
#   /etc/nginx/conf.d/pbx-nclex.conf
#
# Replace these server_name values with real DNS names that point to the host.

upstream pbx_nclex_client {
    server 127.0.0.1:8080;
    keepalive 32;
}

upstream pbx_nclex_admin {
    server 127.0.0.1:8081;
    keepalive 32;
}

upstream pbx_nclex_api {
    server 127.0.0.1:5000;
    keepalive 32;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80;
    server_name drac.ooguy.com;

    location / {
        proxy_pass http://pbx_nclex_client;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 80;
    server_name  admin.drac.ooguy.com;

    location / {
        proxy_pass http://pbx_nclex_admin;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 80;
    server_name api.drac.ooguy.com;

    client_max_body_size 20m;

    location / {
        proxy_pass http://pbx_nclex_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
